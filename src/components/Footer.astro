---
import { Github, Linkedin, Youtube } from 'lucide-astro';

const base = import.meta.env.BASE_URL;
// internal path ('/team') -> base-prefixed href ('/website/team')
const internal = (to) => base + to.replace(/^\//, '');
const year = new Date().getFullYear();

const columns = [
  {
    title: 'Product',
    links: [
      { to: '/features', label: 'Features' },
      { to: '/services', label: 'Services' },
      { href: 'https://editor.besser-pearl.org', label: 'Online editor' },
      { href: 'https://besser.readthedocs.io/en/latest/', label: 'Documentation' },
      { href: 'https://github.com/BESSER-PEARL/BESSER', label: 'Source code' },
    ],
  },
  {
    title: 'Resources',
    links: [
      { href: 'https://modeling-languages.com/', label: 'Blog' },
      { href: 'https://lowcode-book.com/', label: 'Low-code Handbook' },
      { to: '/research', label: 'Research' },
    ],
  },
  {
    title: 'Project',
    links: [
      { to: '/team', label: 'Team' },
      // News hidden until LinkedIn auto-fetch is live
      { to: '/contact', label: 'Contact' },
      { href: 'https://www.list.lu/', label: 'LIST' },
      { href: 'https://www.fnr.lu/', label: 'FNR' },
    ],
  },
];
---

<footer class="border-t border-ink-200 bg-ink-50/60">
  <div class="container-wide grid gap-10 py-14 md:grid-cols-4">
    <div>
      <a href={base} class="inline-flex items-center" aria-label="BESSER home">
        <img src={base + 'brand/besser_logo.webp'} alt="BESSER" class="h-9 w-auto" decoding="async" />
      </a>
      <p class="mt-4 max-w-xs text-sm text-ink-600">
        An open-source low-code platform for building smart, AI-enhanced applications faster.
      </p>
      <div class="mt-5 flex items-center gap-2">
        <a class="rounded-lg p-2 text-ink-600 hover:bg-ink-100 hover:text-ink-900" href="https://github.com/BESSER-PEARL" target="_blank" rel="noopener" aria-label="GitHub"><Github class="h-5 w-5" /></a>
        <a class="rounded-lg p-2 text-ink-600 hover:bg-ink-100 hover:text-ink-900" href="https://www.linkedin.com/company/besser-pearl" target="_blank" rel="noopener" aria-label="LinkedIn"><Linkedin class="h-5 w-5" /></a>
        <a class="rounded-lg p-2 text-ink-600 hover:bg-ink-100 hover:text-ink-900" href="https://www.youtube.com/@BESSER-PEARL" target="_blank" rel="noopener" aria-label="YouTube"><Youtube class="h-5 w-5" /></a>
      </div>
    </div>

    {columns.map((col) => (
      <div>
        <h4 class="font-display text-sm font-semibold uppercase tracking-wider text-ink-900">{col.title}</h4>
        <ul class="mt-4 space-y-2">
          {col.links.map((l) => (
            <li>
              {l.to ? (
                <a class="text-sm text-ink-600 hover:text-ink-900" href={internal(l.to)}>{l.label}</a>
              ) : (
                <a class="text-sm text-ink-600 hover:text-ink-900" href={l.href} target="_blank" rel="noopener">{l.label}</a>
              )}
            </li>
          ))}
        </ul>
      </div>
    ))}
  </div>

  <div class="border-t border-ink-200/80">
    <div class="container-wide flex flex-col items-start justify-between gap-3 py-6 text-xs text-ink-500 sm:flex-row sm:items-center">
      <p>© {year} BESSER · Open source under MIT.</p>
      <p>Funded by <a class="hover:text-ink-700" href="https://www.fnr.lu/" target="_blank" rel="noopener">FNR PEARL</a> at the <a class="hover:text-ink-700" href="https://www.list.lu/" target="_blank" rel="noopener">Luxembourg Institute of Science &amp; Technology</a>.</p>
    </div>
  </div>
</footer>
