---
import Layout from '../../layouts/Layout.astro';
import Reveal from '../../components/Reveal.astro';
import { Icon } from 'astro-icon/components';
import { venues } from '../../data/research';
import { publications } from '../../data/publications';

const byYear = publications.reduce<Record<string, typeof publications>>((acc, p) => {
  (acc[p.year] ||= []).push(p);
  return acc;
}, {});
const years = Object.keys(byYear).sort((a, b) => Number(b) - Number(a));
---
<Layout title="Publications — BESSER Research">
  <section class="container-wide pt-20 pb-10">
    <Reveal class="max-w-3xl">
      <span class="section-eyebrow">Research · Publications</span>
      <h1 class="h2 mt-4 text-4xl sm:text-5xl">Peer-reviewed work from the BESSER team.</h1>
      <p class="lede">Selected papers at the intersection of low-code, modeling, and AI.</p>
      <div class="mt-6 flex flex-wrap gap-3">
        <a href="https://modeling-languages.com/" target="_blank" rel="noopener" class="btn-secondary">
          <Icon name="lucide:book-open" class="h-4 w-4" /> Read the blog
          <Icon name="lucide:arrow-up-right" class="h-4 w-4 opacity-60" />
        </a>
      </div>
    </Reveal>
  </section>

  <section class="container-wide py-16">
    <Reveal>
      <h2 class="font-display text-2xl font-semibold text-ink-900">Publications</h2>
      <p class="mt-1 text-sm text-ink-600">{publications.length} peer-reviewed papers and counting.</p>
    </Reveal>

    <div class="mt-8 space-y-12">
      {years.map((year) => (
        <div>
          <h3 class="mb-4 font-mono text-sm font-medium tracking-widest text-brand-600">{year}</h3>
          <ul class="divide-y divide-ink-200/70 rounded-2xl border border-ink-200/70 bg-white">
            {byYear[year].map((p) => (
              <li class="p-5 transition hover:bg-ink-50/60">
                <a
                  href={p.url || '#'}
                  target={p.url ? '_blank' : undefined}
                  rel={p.url ? 'noopener' : undefined}
                  class={p.url ? 'group block' : 'block cursor-default'}
                >
                  <h4 class="font-display text-base font-semibold leading-snug text-ink-900 group-hover:text-brand-700">
                    {p.title}
                    {p.url && (
                      <Icon name="lucide:arrow-up-right" class="ml-1.5 inline h-3.5 w-3.5 align-text-top opacity-0 transition group-hover:opacity-70" />
                    )}
                  </h4>
                  <p class="mt-1.5 text-sm text-ink-600">{p.authors}</p>
                  <p class="mt-1 text-xs italic text-ink-500">{p.venue}</p>
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </section>

  <section class="container-wide py-16">
    <Reveal>
      <h2 class="font-display text-xl font-semibold text-ink-900">Where our work appears</h2>
      <p class="mt-2 text-sm text-ink-600">A non-exhaustive list of conferences and journals.</p>
      <div class="mt-6 flex flex-wrap gap-2">
        {venues.map((v) => (
          <span class="rounded-full border border-ink-200 bg-white px-3 py-1.5 text-sm text-ink-700">{v}</span>
        ))}
      </div>
    </Reveal>
  </section>
</Layout>
