---
import Layout from '../../layouts/Layout.astro';
import { ExternalLink, Users } from 'lucide-astro';
import { projects } from '../../data/research.js';
---

<Layout title="Projects — BESSER">
  <section class="container-wide pt-20 pb-10">
    <div class="reveal max-w-3xl">
      <span class="section-eyebrow">Research · Projects</span>
      <h1 class="h2 mt-4 text-4xl sm:text-5xl">Active research projects.</h1>
      <p class="lede">Initiatives where BESSER is being put to work — from EU Horizon programmes to open-source tooling for trustworthy AI.</p>
    </div>
  </section>

  <section class="container-wide pb-20">
    <div class="grid gap-5 lg:grid-cols-2">
      {projects.map((p, i) => (
        <article class="reveal card card-hover flex flex-col" style={`transition-delay:${40 * i}ms`}>
          <div class="flex items-baseline justify-between gap-3">
            <h3 class="font-display text-xl font-bold text-ink-900">{p.name}</h3>
            <span class="rounded-full bg-brand-50 px-2.5 py-1 text-xs font-medium text-brand-700">{p.tagline}</span>
          </div>
          <p class="mt-3 text-sm text-ink-600">{p.desc}</p>

          <div class="mt-4 flex items-start gap-2 text-xs text-ink-500">
            <Users class="mt-0.5 h-3.5 w-3.5 shrink-0 opacity-70" />
            <span>{p.contributors.join(' · ')}</span>
          </div>

          {p.links.length > 0 && (
            <div class="mt-4 flex flex-wrap gap-2">
              {p.links.map((l) => (
                <a
                  href={l.href}
                  target="_blank"
                  rel="noopener"
                  class="inline-flex items-center gap-1.5 rounded-lg border border-ink-200 bg-white px-3 py-1.5 text-xs font-medium text-ink-700 hover:border-brand-200 hover:text-brand-700"
                >
                  {l.label} <ExternalLink class="h-3 w-3" />
                </a>
              ))}
            </div>
          )}
        </article>
      ))}
    </div>
  </section>
</Layout>
