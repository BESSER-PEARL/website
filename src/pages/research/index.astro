---
const target = `${import.meta.env.BASE_URL}research/publications`.replace(/\/+/g, '/');
Astro.response.headers.set('Refresh', `0;url=${target}`);
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>Redirecting…</title>
    <meta http-equiv="refresh" content={`0;url=${target}`} />
    <meta name="robots" content="noindex" />
    <link rel="canonical" href={target} />
  </head>
  <body>
    <a href={target}>Redirecting to {target}</a>
  </body>
</html>
