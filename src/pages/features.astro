---
import Layout from '../layouts/Layout.astro';
import Reveal from '../components/Reveal.astro';
import { Icon } from 'astro-icon/components';
import { allFeatures } from '../data/features';
---
<Layout title="Features — BESSER">
  <section class="container-wide py-24">
    <Reveal class="max-w-3xl">
      <span class="section-eyebrow">Features</span>
      <h1 class="h2 mt-4 text-4xl sm:text-5xl">Everything BESSER gives you, in one place.</h1>
      <p class="lede">A complete, open-source low-code toolchain — from modeling to deployment, with AI baked in.</p>
    </Reveal>

    <div class="mt-14 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {allFeatures.map((f, i) => (
        <Reveal as="article" delay={25 * (i % 6)} class="card card-hover">
          <div class="grid h-11 w-11 place-items-center rounded-xl bg-brand-50 text-brand-600">
            <Icon name={`lucide:${f.icon}`} class="h-5 w-5" />
          </div>
          <h2 class="mt-5 font-display text-lg font-semibold text-ink-900" set:html={f.title}></h2>
          <p class="mt-2 text-sm leading-relaxed text-ink-600">{f.desc}</p>
        </Reveal>
      ))}
    </div>
  </section>
</Layout>
