---
import Layout from '../../layouts/Layout.astro';
import { Bot, Network, Sparkles, Wrench, Rocket, Code2, ArrowUpRight, Github } from 'lucide-astro';

// NOTE: first-draft copy — refine with the BAF team before going live.
const capabilities = [
  { icon: Bot,     title: 'Define agents as models',  desc: 'Describe agents, their states, and behaviours with the same model-driven approach as the rest of BESSER — no boilerplate.' },
  { icon: Network, title: 'Multi-agent & A2A',        desc: 'Compose multiple agents that collaborate, with agent-to-agent (A2A) interoperability built in.' },
  { icon: Sparkles,title: 'LLM-agnostic',             desc: 'Plug in the language models you prefer — local or hosted — without rewriting your agent logic.' },
  { icon: Wrench,  title: 'Tools & integrations',     desc: 'Give agents tools and connect them to external systems, APIs, and data sources.' },
  { icon: Rocket,  title: 'Run & deploy',             desc: 'Generate and deploy your agents the same way you ship the rest of your BESSER-built software.' },
  { icon: Code2,   title: 'Free & open source',       desc: 'BAF is part of the open-source BESSER ecosystem — inspect it, fork it, and build on it.' },
];
---

<Layout title="BESSER Agentic Framework — BESSER">
  <section class="container-wide pt-20 pb-10">
    <div class="reveal max-w-3xl">
      <span class="section-eyebrow">Features · Agentic Framework</span>
      <h1 class="h2 mt-4 text-4xl sm:text-5xl">The BESSER Agentic Framework.</h1>
      <p class="lede">
        Model, build, and deploy AI agents the BESSER way — low-code, open source, and LLM-agnostic.
        The Agentic Framework (BAF) brings agents into the same model-driven workflow you already use.
      </p>
      <div class="mt-6 flex flex-wrap gap-3">
        <a href="https://besser.readthedocs.io/en/latest/" target="_blank" rel="noopener" class="btn-primary">
          Read the docs <ArrowUpRight class="h-4 w-4 opacity-70" />
        </a>
        <a href="https://github.com/BESSER-PEARL" target="_blank" rel="noopener" class="btn-secondary">
          <Github class="h-4 w-4" /> View on GitHub
        </a>
      </div>
    </div>
  </section>

  <section class="container-wide pb-24">
    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {capabilities.map((c, i) => {
        const Icon = c.icon;
        return (
          <article class="reveal card card-hover" style={`transition-delay:${25 * (i % 6)}ms`}>
            <div class="grid h-11 w-11 place-items-center rounded-xl bg-brand-50 text-brand-600">
              <Icon class="h-5 w-5" />
            </div>
            <h2 class="mt-5 font-display text-lg font-semibold text-ink-900">{c.title}</h2>
            <p class="mt-2 text-sm leading-relaxed text-ink-600">{c.desc}</p>
          </article>
        );
      })}
    </div>
  </section>
</Layout>
