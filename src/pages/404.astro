---
import Layout from '../layouts/Layout.astro';

const homeHref = import.meta.env.BASE_URL;
---
<Layout title="Page not found — BESSER">
  <section class="container-narrow grid min-h-[60vh] place-items-center py-24 text-center">
    <div>
      <p class="font-mono text-sm font-medium text-brand-600">404</p>
      <h1 class="mt-3 font-display text-4xl font-bold text-ink-900">Page not found</h1>
      <p class="mt-3 text-ink-600">That URL doesn&rsquo;t exist (yet).</p>
      <a href={homeHref} class="btn-primary mt-8">Take me home</a>
    </div>
  </section>
</Layout>
