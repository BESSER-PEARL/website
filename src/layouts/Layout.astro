---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../index.css';

const {
  title = 'BESSER — Better Software, Faster',
  description = 'BESSER — open-source low-code platform to build smart applications faster. Free, AI-powered, model-driven.',
  noindex = false,
} = Astro.props;

const base = import.meta.env.BASE_URL;

// Absolute canonical URL + logo (needs `site` in astro.config).
const canonical = Astro.site ? new URL(Astro.url.pathname, Astro.site).href : undefined;
const logo = Astro.site ? new URL(`${base}brand/besser_logo.webp`, Astro.site).href : undefined;
// Social share image (1200×630). See public/og-card.html for the source design.
const ogImage = Astro.site ? new URL(`${base}og-image.png`, Astro.site).href : undefined;

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'BESSER',
  alternateName: 'BESSER PEARL',
  url: Astro.site?.href ?? 'https://besser-pearl.org',
  ...(logo ? { logo } : {}),
  description:
    'BESSER is an open-source, AI-enhanced low-code platform for building smart software faster.',
  sameAs: [
    'https://github.com/BESSER-PEARL',
    'https://www.linkedin.com/company/besser-pearl',
    'https://www.youtube.com/@BESSER-PEARL',
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#ffffff" />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    {canonical && <link rel="canonical" href={canonical} />}
    <link rel="icon" type="image/x-icon" href={`${base}favicon.ico`} />

    {/* Open Graph (LinkedIn, Slack, Facebook, …) */}
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="BESSER" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {canonical && <meta property="og:url" content={canonical} />}
    {ogImage && <meta property="og:image" content={ogImage} />}
    {ogImage && <meta property="og:image:alt" content="BESSER — Better software, faster." />}

    {/* Twitter / X */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}

    <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Space+Grotesk:wght@500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
    <noscript><style>.reveal { opacity: 1 !important; transform: none !important; }</style></noscript>
  </head>
  <body class="bg-white text-ink-900 antialiased">
    <div class="flex min-h-screen flex-col">
      <Nav />
      <main class="flex-1"><slot /></main>
      <Footer />
    </div>

    <script>
      // CSS scroll-reveal — replaces Framer Motion's whileInView fade-up.
      const reveal = () => {
        const els = document.querySelectorAll('.reveal:not(.is-visible)');
        if (!('IntersectionObserver' in window)) {
          els.forEach((el) => el.classList.add('is-visible'));
          return;
        }
        const io = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                io.unobserve(entry.target);
              }
            }
          },
          { rootMargin: '0px 0px -60px 0px' },
        );
        els.forEach((el) => io.observe(el));
      };
      reveal();
    </script>
  </body>
</html>
