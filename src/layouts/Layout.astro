---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../index.css';

const {
  title = 'BESSER — Better Software, Faster',
  description = 'BESSER — open-source low-code platform to build smart applications faster. Free, AI-powered, model-driven.',
} = Astro.props;

const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#ffffff" />
    <link rel="icon" type="image/x-icon" href={`${base}favicon.ico`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Space+Grotesk:wght@500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
    <noscript><style>.reveal { opacity: 1 !important; transform: none !important; }</style></noscript>
  </head>
  <body class="bg-white text-ink-900 antialiased">
    <div class="flex min-h-screen flex-col">
      <Nav />
      <main class="flex-1"><slot /></main>
      <Footer />
    </div>

    <script>
      // CSS scroll-reveal — replaces Framer Motion's whileInView fade-up.
      const reveal = () => {
        const els = document.querySelectorAll('.reveal:not(.is-visible)');
        if (!('IntersectionObserver' in window)) {
          els.forEach((el) => el.classList.add('is-visible'));
          return;
        }
        const io = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                io.unobserve(entry.target);
              }
            }
          },
          { rootMargin: '0px 0px -60px 0px' },
        );
        els.forEach((el) => io.observe(el));
      };
      reveal();
    </script>
  </body>
</html>
